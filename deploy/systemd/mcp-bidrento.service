[Unit]
Description=Bidrento MCP Server
After=network.target

[Service]
Type=simple
User=bdroapi
Group=bdroapi
WorkingDirectory=/home/bdroapi/bidrento-mcp
ExecStart=/usr/bin/node dist/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=LOG_LEVEL=info

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=no
ReadWritePaths=/home/bdroapi/bidrento-mcp
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
