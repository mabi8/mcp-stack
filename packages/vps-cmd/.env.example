# VPS Command MCP — Environment
# Copy to .env and fill in values

# MCP server config
MCP_PORT=9445
SERVER_ORIGIN=https://sss.makkib.com

# SSH private key path (for connecting to worker VPS)
SSH_KEY_PATH=/home/ops/.ssh/id_ed25519

# Audit log directory (append-only, owned by root)
AUDIT_LOG_DIR=/var/log/vps-cmd

# Optional: TLS (if terminating TLS here instead of nginx)
# TLS_CERT=/etc/letsencrypt/live/sss.makkib.com/fullchain.pem
# TLS_KEY=/etc/letsencrypt/live/sss.makkib.com/privkey.pem

# Passphrase for OAuth authorize (generate with: openssl rand -base64 32 | tr -d '=' | head -c 32)
AUTH_PASSPHRASE=

# Rate limit: max commands per minute per session
RATE_LIMIT_PER_MIN=10
