{
  "hosts": {
    "box": {
      "hostname": "box.makkib.com",
      "port": 22,
      "username": "ops",
      "services": [
        "mcp-centerdevice",
        "mcp-bidrento",
        "bcl-telegram",
        "bcl-wa-bot",
        "log-mcp",
        "mcp-vps-cmd"
      ],
      "repos": {
        "mcp-stack": "/home/ops/mcp-stack",
        "bcl-telegram-claude": "/home/bclai/bcl-telegram-claude",
        "log-mcp": "/home/ops/log-mcp"
      },
      "readablePaths": [
